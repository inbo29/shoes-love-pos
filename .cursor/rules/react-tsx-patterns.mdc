## 금지 패턴

```tsx
// ❌ 인라인 스타일 금지
<div style={{ padding: '24px' }}>

// ❌ 하드코딩된 색상값 (테마 색상 외)
<div className="bg-[#123456]">

// ❌ 클래스 컴포넌트 금지
class MyComponent extends React.Component { }

// ❌ any 타입 남용 금지
const data: any = fetchData();

// ❌ useEffect 의존성 배열 누락 금지
useEffect(() => { /* ... */ }); // 빈 배열이라도 명시
```
