# React/TSX 컴포넌트 패턴

## 컴포넌트 구조 템플릿

### Screen 컴포넌트
```tsx
import React, { useState, useEffect } from 'react';
import { useNavigate, useParams } from 'react-router-dom';

interface ScreenNameProps {
  userName?: string;
  initialBranch?: string;
}

const ScreenName: React.FC<ScreenNameProps> = ({ userName, initialBranch }) => {
  const navigate = useNavigate();
  
  // State
  const [data, setData] = useState<DataType[]>([]);
  const [loading, setLoading] = useState(false);
  
  // Effects
  useEffect(() => {
    // 초기 데이터 로드
  }, []);
  
  // Handlers
  const handleAction = () => {
    // 액션 처리
  };
  
  return (
    <div className="flex-1 flex flex-col p-8 gap-10 overflow-y-auto bg-[#F8F9FA] no-scrollbar">
      {/* Content */}
    </div>
  );
};

export default ScreenName;
```

### Step 컴포넌트
```tsx
interface StepNNameProps {
  onValidationChange?: (isValid: boolean) => void;
}

const StepNName: React.FC<StepNNameProps> = ({ onValidationChange }) => {
  // Validation Effect 필수
  useEffect(() => {
    const isValid = /* validation logic */;
    onValidationChange?.(isValid);
  }, [/* dependencies */, onValidationChange]);
  
  return (
    <div className="w-full h-full flex flex-col p-4 md:p-6 overflow-y-auto no-scrollbar">
      {/* 2 Column Layout for STEP screens */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-6 h-full">
        {/* Left: Main Content */}
        <section className="bg-surface-light rounded-2xl shadow-sm border border-gray-100 p-6">
          {/* ... */}
        </section>
        
        {/* Right: Summary Panel (sticky) */}
        <section className="bg-surface-light rounded-2xl shadow-sm border border-gray-100 p-6">
          {/* ... */}
        </section>
      </div>
    </div>
  );
};
```

